# ============================================================
# Smartbox Content Engine — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ============================================================

# ---- Text LLM (pick one or let it fall back to Ollama) ----

# Option 1: Anthropic Claude (highest quality, paid)
ANTHROPIC_API_KEY=

# Option 2: OpenRouter — free open-source models (Qwen, DeepSeek, Llama)
# Sign up free at https://openrouter.ai
OPENROUTER_API_KEY=
# Best free models for brand copywriting:
#   qwen/qwen-2.5-72b-instruct:free   (Alibaba Qwen — recommended)
#   deepseek/deepseek-chat-v3-0324:free  (DeepSeek V3 — excellent)
#   meta-llama/llama-3.3-70b:free     (Meta fallback)
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct:free

# Option 3: Local Ollama fallback (no API key needed, must be running locally)
OLLAMA_URL=http://localhost:11434

# Claude model if using Anthropic
LLM_MODEL=claude-sonnet-4-5

# ---- Image Generation ----
# Pollinations.ai is always used for free (no key needed).
# Optionally add HuggingFace token for FLUX.1-schnell fallback.
# Sign up free at https://huggingface.co
HF_API_KEY=

# ---- Video Generation ----
# Option A: Fal.ai — Wan 2.1 (Alibaba open-source), Kling (Kuaishou)
# Sign up at https://fal.ai — ~$10 free credits on signup (~200 test videos)
FAL_API_KEY=

# Option B: Replicate — Wan 2.2 fast ($0.05/video)
# Sign up at https://replicate.com — $5 free credits on signup
REPLICATE_API_KEY=

# ---- App settings ----
DEFAULT_LOCALE=IE
